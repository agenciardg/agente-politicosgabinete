# =====================================================
# CONFIGURACOES - AGENTE LANGGRAPH MULTI-TENANT
# =====================================================

# ==========================================
# Supabase (config tables: tenants, agents, panels, fields)
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ==========================================
# PostgreSQL Dedicado (checkpoints + memory)
# ==========================================
POSTGRES_HOST=your-database-host
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=your-database-user
POSTGRES_PASSWORD=your-database-password

# Pool de Conexoes
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ==========================================
# xAI Grok API (default LLM, overridable per tenant)
# ==========================================
GROK_API_KEY=your-xai-grok-api-key
GROK_MODEL=grok-4-1-fast-non-reasoning
GROK_BASE_URL=https://api.x.ai/v1
GROK_TEMPERATURE=0.1
GROK_TOP_P=0.3

# ==========================================
# Helena CRM API (default, overridable per tenant)
# ==========================================
HELENA_API_TOKEN=your-helena-api-token
HELENA_BASE_URL=https://api.helena.run
HELENA_BOT_NUMBER=+5511999999999

# ==========================================
# FastAPI
# ==========================================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# ==========================================
# Environment
# ==========================================
ENVIRONMENT=development
LOG_LEVEL=INFO
TZ=America/Sao_Paulo
WORKERS=2
